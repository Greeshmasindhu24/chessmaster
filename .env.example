# Application
APP_NAME=ChessMaster Pro
DEBUG=true
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Database â€” SQLite is the default for Windows dev (no PostgreSQL required)
SQLITE_DATABASE_URL=sqlite+aiosqlite:///./data/chessmaster.db
# PostgreSQL (optional â€” production or when you need Postgres features)
# DATABASE_URL=postgresql+asyncpg://chess:chess@localhost:5433/chessmaster

# Redis (optional â€” leave empty to use in-memory cache for local dev)
REDIS_ENABLED=false
REDIS_URL=

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","http://localhost:3000","http://127.0.0.1:3000"]

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/api/v1/auth/google/callback

# Email — verification & password reset (create ChessMasterPro/.env from this file)
# If SMTP_HOST, SMTP_USER, and SMTP_PASSWORD are empty, the API skips sending email and
# returns verify_url in register/resend responses (dev banner in the UI). Set all three
# to send real emails to the user's inbox.
#
# --- Gmail (app password) ---
# 1. Google Account → Security → 2-Step Verification (required)
# 2. Security → App passwords → create "Mail" app → copy 16-char password
# 3. Paste below and restart the backend (run_backend.ps1)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM=your@gmail.com
#
# --- Brevo (free tier, 300 emails/day) ---
# 1. Sign up at brevo.com → SMTP & API → SMTP keys
# 2. Use login email + generated SMTP key (not your account password)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login@email.com
# SMTP_PASSWORD=your-brevo-smtp-key
# SMTP_FROM=your-verified-sender@yourdomain.com
#
# --- SendGrid (free tier) ---
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# SMTP_FROM=your-verified-sender@yourdomain.com
#
# FRONTEND_URL must match where you open the app (verification links use this host).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@chessmaster.pro

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Local paths (Windows)
UPLOADS_DIR=uploads
STOCKFISH_PATH=stockfish/stockfish.exe

# Frontend
# Leave empty in frontend/.env.local to use Vite proxy (recommended for dev)

